# === COMPASS (use later on company laptop) ===
# OPENAI_API_KEY=<your-real-compass-key>
# OPENAI_BASE_URL=https://compass.core42.ai/v1
# COMPASS_MODEL=gpt-4.1
# COMPASS_REASONING_MODEL=gpt-5.1
# EMBEDDING_MODEL=text-embedding-3-large

# === OLLAMA (local development) ===
OPENAI_API_KEY=ollama-local-dev
OPENAI_BASE_URL=http://localhost:11434/v1
COMPASS_MODEL=llama3.2:3b
COMPASS_REASONING_MODEL=llama3.2:3b
EMBEDDING_MODEL=nomic-embed-text

# === Runtime ===
SAMPLE_MODE=false
LOG_LEVEL=INFO
MAX_AGENT_ITERATIONS=2
CREWAI_TELEMETRY_OPT_OUT=true
TOP_K_PAPERS=5